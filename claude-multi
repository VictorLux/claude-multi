def load_config(config_path: str) -> dict:
    """Load config from TOML file. Create default if missing."""
    path = Path(config_path)

    if not path.exists():
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(DEFAULT_CONFIG_CONTENT)
        os.chmod(path, 0o600)

    # Warn if permissions too open
    if path.exists():
        perms = stat.S_IMODE(path.stat().st_mode)
        if perms & 0o077:
            print(
                f"WARNING: Config {path} has overly permissive permissions "
                f"({oct(perms)}). Recommend: chmod 600 {path}",
                file=sys.stderr,
            )

    with open(path, "rb") as f:
        raw = tomllib.load(f)

    config = {
        "layout": raw.get("layout", DEFAULT_LAYOUT),
        "palette": raw.get("palette", list(DEFAULT_PALETTE)),
        "upgrade_check_interval": raw.get(
            "upgrade_check_interval", DEFAULT_UPGRADE_INTERVAL
        ),
        "projects": raw.get("projects", []),
    }

    # Validate layout
    if config["layout"] not in ("grid", "horizontal", "vertical"):
        print(
            f"WARNING: Invalid layout '{config['layout']}', using 'grid'",
            file=sys.stderr,
        )
        config["layout"] = "grid"

    return config


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    """Parse CLI arguments."""
    parser = argparse.ArgumentParser(
        prog="claude-multi",
        description="Launch multiple Claude Code sessions in tmux panes.",
    )
    parser.add_argument(
        "projects",
        nargs="*",
        default=[],
        help="Project directories to open (overrides config file)",
    )
    parser.add_argument(
        "--layout",
        choices=["grid", "horizontal", "vertical"],
        default=None,
        help="Pane layout (default: from config or 'grid')",
    )
    parser.add_argument(
        "--config",
        default=str(DEFAULT_CONFIG_PATH),
        help="Config file path",
    )
    parser.add_argument(
        "--session",
        default="claude-multi",
        help="Tmux session name (default: claude-multi)",
    )
    parser.add_argument(
        "--detach",
        action="store_true",
        help="Create session in background without attaching",
    )
    parser.add_argument(
        "--keys",
        action="store_true",
        help="Show keybinding reference and exit",
    )
    parser.add_argument(
        "--skills",
        action="store_true",
        help="Show available skill presets and exit",
    )
    parser.add_argument(
        "--version",
        action="version",
        version=f"claude-multi {VERSION}",
    )
    return parser.parse_args(argv)


def sanitize_name(name: str) -> str:
    """Sanitize string for use as tmux pane/session name."""
    sanitized = re.sub(r"[^a-zA-Z0-9_-]", "", name)
    if not sanitized:
        sanitized = "unnamed"
    return sanitized[:256]


def resolve_skill(project_cfg: dict) -> dict:
    """Resolve skill/model/prompt settings from a project config entry.

    Priority: system_prompt > skill preset > nothing.
    Returns dict with keys: label, system_prompt, model (all optional).
    """
    result = {}

    # Model override
    model = project_cfg.get("model")
    if model:
        result["model"] = model

    # Effort override
    effort = project_cfg.get("effort")
    if effort:
        result["effort"] = effort

    # System prompt — explicit takes priority over skill preset
    system_prompt = project_cfg.get("system_prompt")
    skill_name = project_cfg.get("skill")

    if system_prompt:
        result["system_prompt"] = system_prompt
        result["label"] = project_cfg.get("label", "custom")
    elif skill_name:
        preset = SKILL_PRESETS.get(skill_name)
        if preset:
            result["system_prompt"] = preset["prompt"]
            result["label"] = project_cfg.get("label", preset["label"])
        else:
            valid = ", ".join(sorted(SKILL_PRESETS.keys()))
            print(
                f"WARNING: Unknown skill '{skill_name}'. "
                f"Available: {valid}",
                file=sys.stderr,
            )

    # Explicit label always wins
    if "label" in project_cfg:
        result["label"] = project_cfg["label"]

    return result


def validate_projects(
    paths: list[str],
    palette: list[str],
    config_projects: list[dict] | None = None,
) -> list[dict]:
    """Validate project paths, deduplicate, assign colors and skills."""
    config_projects = config_projects or []

    # Build lookup maps from config (keyed by resolved path)
    config_by_path: dict[str, list[dict]] = {}
    for cp in config_projects:
        resolved = str(Path(cp["path"]).expanduser().resolve())
        config_by_path.setdefault(resolved, []).append(cp)

    # When loading from config (no CLI paths), use config_projects directly
    # When loading from CLI paths, use path-based lookup
    seen_keys: set[str] = set()
    projects = []

    items_to_process: list[dict] = []
    if paths:
        # CLI paths — simple mode, one pane per path
        for raw_path in paths:
            items_to_process.append({"path": raw_path})
    else:
        # Config mode — use config entries directly (allows same path with different skills)
        items_to_process = list(config_projects)

    for i, item in enumerate(items_to_process):
        raw_path = item.get("path", "")
        if len(raw_path) > 4096:
            print(f"WARNING: Path too long, skipping: {raw_path[:80]}...", file=sys.stderr)
            continue

        path = Path(raw_path).expanduser().resolve()

        if not path.exists():
            print(f"WARNING: Path does not exist, skipping: {path}", file=sys.stderr)
            continue
        if not path.is_dir():
            print(f"WARNING: Not a directory, skipping: {path}", file=sys.stderr)
            continue

        path_str = str(path)

        # Dedup key: path + skill/label combo (same path with different skills is OK)
        skill_info = resolve_skill(item)
        dedup_key = f"{path_str}:{skill_info.get('label', '')}:{skill_info.get('model', '')}"
        if dedup_key in seen_keys:
            print(f"WARNING: Duplicate path+skill, skipping: {path}", file=sys.stderr)
            continue
        seen_keys.add(dedup_key)

        # Color from config or palette
        color = item.get("color", palette[len(projects) % len(palette)])
        name = sanitize_name(path.name)

        # Build display name with skill label
        label = skill_info.get("label")
        display_name = f"{name}/{label}" if label else name

        proj = {
            "path": path,
            "name": display_name,
            "color": color,
        }

        # Add optional skill settings
        if "system_prompt" in skill_info:
            proj["system_prompt"] = skill_info["system_prompt"]
        if "model" in skill_info:
            proj["model"] = skill_info["model"]
        if "effort" in skill_info:
            proj["effort"] = skill_info["effort"]

        # Background color from config
        bg = item.get("bg")
        if bg:
            proj["bg"] = bg

        projects.append(proj)

        if len(projects) >= MAX_SESSIONS:
            if i < len(paths) - 1:
                print(
                    f"WARNING: Max {MAX_SESSIONS} sessions. Ignoring remaining projects.",
                    file=sys.stderr,
                )
            break

    return projects


SHARED_FILE = ".claude-multi-shared.md"

SHARED_FILE_TEMPLATE = """\
# claude-multi shared notes

This file is shared between all Claude Code sessions working on this project.
Use it to coordinate, share findings, and pass context between sessions.

## Active sessions
{sessions}

## Shared Notes
<!-- Write your findings, decisions, and context below -->
<!-- Other sessions in this project will read this file -->

"""


def enrich_with_team_context(projects: list[dict]) -> list[dict]:
    """Add team awareness to each project's system prompt.

    Groups projects by path, then for each project with teammates,
    appends collaboration instructions to the system prompt.
    Creates/updates the shared notes file in each project directory.
    """
    # Group by resolved path
    by_path: dict[str, list[dict]] = {}
    for proj in projects:
        key = str(proj["path"])
        by_path.setdefault(key, []).append(proj)

    for path_str, teammates in by_path.items():
        if len(teammates) < 2:
            continue

        path = Path(path_str)

        # Build team roster for the shared file
        session_lines = ""
        for t in teammates:
            model = t.get("model", "default")
            effort = t.get("effort", "default")
            session_lines += f"- **{t['name']}** (model: {model}, effort: {effort})\n"

        # Create/update shared file
        shared_path = path / SHARED_FILE
        if not shared_path.exists():
            shared_path.write_text(
                SHARED_FILE_TEMPLATE.format(sessions=session_lines)
            )

        # Add team context to each teammate's system prompt
        for proj in teammates:
            team_desc = []
            for t in teammates:
                if t is not proj:
                    team_desc.append(f"  - {t['name']} ({t.get('model', 'default')})")

            collab_prompt = (
                f"\n\n## MANDATORY FIRST ACTION\n"
                f"Before doing ANYTHING else, you MUST read the file `{SHARED_FILE}` in the project root.\n"
                f"This file contains critical context from your teammates. Do not skip this step.\n"
                f"If the file does not exist, create it with a header noting your role.\n"
                f"\n## Team Collaboration\n"
                f"You are part of a team of Claude sessions working on this project simultaneously.\n"
                f"Your role: **{proj['name']}**\n"
                f"Your teammates:\n" + "\n".join(team_desc) + "\n\n"
                f"Coordination rules:\n"
                f"- ALWAYS read `{SHARED_FILE}` before starting any task and before major decisions.\n"
                f"- ALWAYS write your key findings, decisions, progress, and warnings to `{SHARED_FILE}` after completing work.\n"
                f"- Prefix ALL your entries with your role name [{proj['name']}] and a timestamp.\n"
                f"- Do NOT edit or delete other sessions' entries.\n"
                f"- If you see a warning or blocker from a teammate, acknowledge it and adapt your work accordingly.\n"
                f"- Before modifying any file, check `{SHARED_FILE}` to see if a teammate is already working on it. If so, coordinate by writing your intent first.\n"
                f"- When you finish a task or find something important, update `{SHARED_FILE}` immediately — your teammates depend on it.\n"
            )

            base_prompt = proj.get("system_prompt", "")
            proj["system_prompt"] = base_prompt + collab_prompt

    return projects


def get_version_output(cmd: list[str], timeout: int = 5) -> str:
    """Run a command and return stdout, or empty string on failure."""
    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=timeout
        )
        return result.stdout.strip()
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
        return ""


def check_dependencies() -> dict:
    """Check that tmux and claude are installed. Returns version info. Exits on failure."""
    info = {}

    # Check tmux
    if not shutil.which("tmux"):
        print(
            "ERROR: tmux is not installed.\n"
            "  macOS: brew install tmux\n"
            "  Ubuntu/Debian: sudo apt install tmux\n"
            "  Fedora: sudo dnf install tmux",
            file=sys.stderr,
        )
        sys.exit(1)

    tmux_ver = get_version_output(["tmux", "-V"])
    info["tmux_version"] = tmux_ver

    # Check tmux version >= 2.3
    match = re.search(r"(\d+)\.(\d+)", tmux_ver)
    if match:
        major, minor = int(match.group(1)), int(match.group(2))
        if (major, minor) < (2, 3):
            print(
                f"ERROR: tmux {tmux_ver} is too old. Need tmux 2.3+ "
                "for pane-border-format support.",
                file=sys.stderr,
            )
            sys.exit(1)

    # Check claude
    if not shutil.which("claude"):
        print(
            "ERROR: Claude Code CLI is not installed.\n"
            "  Install: npm install -g @anthropic-ai/claude-code",
            file=sys.stderr,
        )
        sys.exit(1)

    claude_ver_raw = get_version_output(["claude", "--version"])
    # Extract just the semver (e.g. "2.1.83" from "2.1.83 (Claude Code)")
    ver_match = re.search(r"(\d+\.\d+\.\d+)", claude_ver_raw)
    info["claude_version"] = ver_match.group(1) if ver_match else claude_ver_raw

    return info


def validate_safe_path(path: Path) -> None:
    """Validate a path is safe for interpolation into shell strings."""
    path_str = str(path)
    if not SAFE_PATH_RE.match(path_str):
        raise ValueError(
            f"Path contains unsafe characters for shell interpolation: {path_str}"
        )


def generate_tmux_conf(
    conf_path: Path,
    scripts_dir: Path,
    session_name: str,
    upgrade_check_interval: int,
) -> None:
    """Generate dedicated tmux.conf for claude-multi."""
    validate_safe_path(scripts_dir)
    safe_session = sanitize_name(session_name)

    conf_path.parent.mkdir(parents=True, exist_ok=True)

    # Build upgrade timer block if enabled
    upgrade_timer = ""
    if upgrade_check_interval > 0:
        interval_sec = upgrade_check_interval * 60
        upgrade_timer = f"""
# Upgrade check timer (every {upgrade_check_interval} minutes)
# Self-rescheduling: check-upgrade.sh reschedules itself at the end
set-hook -g after-new-session "run-shell -b '{scripts_dir}/check-upgrade.sh {safe_session} {interval_sec}'"
"""

    content = f"""\
# claude-multi tmux configuration (auto-generated)
# Do not edit — regenerated on each launch

# Enable pane border status at top
set-option -wg pane-border-status top

# Active pane: bright green arrow + bold info. Inactive: dim grey.
set-option -wg pane-border-format "#{{?pane_active,#[fg=colour46 bold] ▶ #{{@cm_info}} ,#[fg=colour240]   #{{@cm_info}} }}"

# Active border: bright green. Inactive: dark grey.
set-option -g pane-active-border-style "fg=colour46,bold"
set-option -g pane-border-style "fg=colour240"

# Mouse support (click to switch panes)
set-option -g mouse on

# Status bar — help shortcuts
set-option -g status on
set-option -g status-position bottom
set-option -g status-style "bg=colour233,fg=colour245"
set-option -g status-left "#[bg=colour22,fg=colour46,bold] claude-multi #[default] "
set-option -g status-left-length 20
set-option -g status-right " #[fg=colour250]^B+Arrows#[fg=colour240]:navigate #[fg=colour250]^B+r#[fg=colour240]:restart #[fg=colour250]^B+R#[fg=colour240]:all #[fg=colour250]^B+U#[fg=colour240]:upgrade #[fg=colour250]^B+z#[fg=colour240]:zoom #[fg=colour250]^B+x#[fg=colour240]:close #[fg=colour250]^B+d#[fg=colour240]:detach "
set-option -g status-right-length 150
set-option -g window-status-format ""
set-option -g window-status-current-format ""
{upgrade_timer}
# Keybindings
bind-key r run-shell "{scripts_dir}/restart.sh '#{{pane_id}}' {safe_session}"
bind-key R run-shell "{scripts_dir}/restart-all.sh {safe_session}"
bind-key U split-window -v "{scripts_dir}/upgrade.sh {safe_session}"
"""
    conf_path.write_text(content)


def build_layout_commands(
    layout: str, projects: list[dict], session_name: str
) -> list[list[str]]:
    """Build tmux commands to create panes in the requested layout.

    Grid layout groups by project: left column = first project, right column = second.
    Projects should be sorted by path before calling this function.
    """
    n = len(projects)
    if n <= 1:
        return []

    cmds: list[list[str]] = []
    target = f"{session_name}:0"

    if layout == "grid" and n >= 4:
        # 2-column grid: group by project (left col / right col)
        # Count how many unique projects and split into left/right
        unique_paths = []
        for p in projects:
            ps = str(p["path"])
            if ps not in unique_paths:
                unique_paths.append(ps)

        if len(unique_paths) >= 2:
            # Split: left half = first project(s), right half = rest
            mid = n // 2
            left_count = mid
            right_count = n - mid

            # First pane (index 0) already exists — it's top-left
            # Create right column with a horizontal split
            cmds.append([
                "tmux", "split-window", "-t", f"{target}.0", "-h", "-d",
            ])
            # Now pane 0 = left, pane 1 = right

            # Split left column vertically for additional left panes
            for i in range(1, left_count):
                cmds.append([
                    "tmux", "split-window", "-t", f"{target}.0", "-v", "-d",
                ])

            # Split right column vertically for additional right panes
            # Right column starts at pane index = left_count
            for i in range(1, right_count):
                cmds.append([
                    "tmux", "split-window", "-t", f"{target}.{left_count}", "-v", "-d",
                ])

            return cmds

        # Fallback: single project with 4+ panes — use tiled
        for _ in range(1, n):
            cmds.append(["tmux", "split-window", "-t", target, "-d"])
            cmds.append(["tmux", "select-layout", "-t", target, "tiled"])
        return cmds

    # For 2-3 panes grid or other layouts
    for _ in range(1, n):
        cmds.append([
            "tmux", "split-window", "-t", target, "-d",
        ])
        if layout == "grid":
            cmds.append(["tmux", "select-layout", "-t", target, "tiled"])
        elif layout == "horizontal":
            cmds.append(["tmux", "select-layout", "-t", target, "even-horizontal"])
        elif layout == "vertical":
            cmds.append(["tmux", "select-layout", "-t", target, "even-vertical"])

    return cmds


def write_script(path: Path, content: str) -> None:
    """Write a shell script with secure permissions (0o700)."""
    path.write_text(content)
    os.chmod(path, 0o700)


def generate_scripts(scripts_dir: Path) -> None:
    """Generate helper shell scripts for tmux keybindings."""
    scripts_dir.mkdir(parents=True, exist_ok=True)

    # pane-wrapper.sh — launched in each pane via send-keys, handles restart loop
    write_script(scripts_dir / "pane-wrapper.sh", """\
#!/bin/bash
# Pane wrapper for claude-multi
# Args: $1=project_path $2=project_name $3=color
# Optional env: CM_MODEL, CM_SYSTEM_PROMPT_FILE, CM_EFFORT
set -euo pipefail

PROJECT_PATH="$1"
PROJECT_NAME="$2"
COLOR="$3"
PANE_ID="${TMUX_PANE:-}"
MODEL="${CM_MODEL:-}"
PROMPT_FILE="${CM_SYSTEM_PROMPT_FILE:-}"
EFFORT="${CM_EFFORT:-}"

cd "$PROJECT_PATH"

get_claude_version() {
    claude --version 2>/dev/null | head -1 | grep -oE '[0-9]+\\.[0-9]+\\.[0-9]+' || echo "unknown"
}

# Build claude command as an array (no eval needed)
build_claude_cmd() {
    local mode="$1"  # "start" or "continue"
    CMD=(claude)
    if [ "$mode" = "continue" ]; then
        CMD+=(--continue)
    fi
    CMD+=(--name "$PROJECT_NAME")
    if [ -n "$MODEL" ]; then
        CMD+=(--model "$MODEL")
    fi
    if [ -n "$EFFORT" ]; then
        CMD+=(--effort "$EFFORT")
    fi
    if [ -n "$PROMPT_FILE" ] && [ -f "$PROMPT_FILE" ]; then
        CMD+=(--system-prompt "$(cat "$PROMPT_FILE")")
    fi
}

update_title() {
    local status="$1"
    local ver
    ver=$(get_claude_version)
    local model_tag=""
    if [ -n "$MODEL" ] && [ -n "$EFFORT" ]; then
        model_tag=" ($MODEL/$EFFORT)"
    elif [ -n "$MODEL" ]; then
        model_tag=" ($MODEL)"
    elif [ -n "$EFFORT" ]; then
        model_tag=" ($EFFORT)"
    fi
    if [ -n "$PANE_ID" ]; then
        tmux set-option -p -t "$PANE_ID" @cm_info "[$PROJECT_NAME] claude $ver$model_tag $status" 2>/dev/null || true
    fi
}

FIRST_RUN=1
while true; do
    if [ "$FIRST_RUN" -eq 1 ]; then
        update_title "● running"
        build_claude_cmd "start"
        "${CMD[@]}" || true
        FIRST_RUN=0
    else
        update_title "● restarting..."
        sleep 1
        update_title "● running"
        build_claude_cmd "continue"
        "${CMD[@]}" || { build_claude_cmd "start"; "${CMD[@]}" || true; }
    fi

    update_title "● stopped"
    echo ""
    echo "Claude session ended. Press Enter to restart or Ctrl+C to exit pane."
    read -r || break
done
""")

    # restart.sh — restart claude in a specific pane using SIGTERM
    write_script(scripts_dir / "restart.sh", """\
#!/bin/bash
# Restart claude in a specific pane
# Args: $1=pane_id $2=session_name
set -uo pipefail
PANE_ID="$1"
SESSION="$2"

# Only restart panes managed by claude-multi (have @cm_info set)
CM_INFO=$(tmux show-options -p -t "$PANE_ID" -v @cm_info 2>/dev/null || echo "")
if [ -z "$CM_INFO" ]; then
    exit 0
fi

# Send Ctrl+C to stop Claude gracefully, wait, then Enter to trigger wrapper restart
tmux send-keys -t "$PANE_ID" C-c
sleep 3
tmux send-keys -t "$PANE_ID" "" Enter
""")

    # restart-all.sh — restart all panes
    write_script(scripts_dir / "restart-all.sh", """\
#!/bin/bash
# Restart claude in all managed panes (skips temp panes like upgrade)
# Args: $1=session_name
set -uo pipefail
SESSION="$1"
SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"

# Only restart panes that have @cm_info (managed by claude-multi)
PANES=$(tmux list-panes -t "$SESSION" -F '#{pane_id}' 2>/dev/null || echo "")
for PANE in $PANES; do
    CM_INFO=$(tmux show-options -p -t "$PANE" -v @cm_info 2>/dev/null || echo "")
    if [ -n "$CM_INFO" ]; then
        bash "$SCRIPTS_DIR/restart.sh" "$PANE" "$SESSION" &
    fi
done
wait
""")

    # upgrade.sh — confirm, upgrade claude, then restart all
    write_script(scripts_dir / "upgrade.sh", """\
#!/bin/bash
# Upgrade Claude Code and restart all panes
# Args: $1=session_name
set -uo pipefail
SESSION="$1"
SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "=== Claude Code Upgrade ==="
echo ""
echo "This will run: npm update -g @anthropic-ai/claude-code"
echo "This affects Claude Code globally on this system."
echo ""
printf "Proceed? [y/N] "
read -r CONFIRM

if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
    echo "Upgrade cancelled."
    sleep 2
    exit 0
fi

echo ""
echo "Upgrading..."
if npm update -g @anthropic-ai/claude-code; then
