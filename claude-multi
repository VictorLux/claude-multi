    echo "Upgrade complete! New version: $NEW_VER"
    echo ""
    echo "Now restart your panes to use the new version:"
    echo "  Ctrl+B r  → restart current pane"
    echo "  Ctrl+B R  → restart all panes"
    echo ""
    echo "Press Enter to close this window."
    read -r
else
    echo ""
    echo "ERROR: Upgrade failed. Check permissions (you may need sudo)."
    echo "Press Enter to close."
    read -r
    exit 1
fi
""")

    # check-upgrade.sh — silent upgrade check, self-rescheduling timer
    write_script(scripts_dir / "check-upgrade.sh", """\
#!/bin/bash
# Check for Claude Code upgrades (self-rescheduling tmux timer)
# Args: $1=session_name $2=interval_seconds
set -uo pipefail
SESSION="$1"
INTERVAL="${2:-1800}"

# Get installed version
LOCAL_VER=$(claude --version 2>/dev/null | head -1 | grep -oE '[0-9]+\\.[0-9]+\\.[0-9]+' || echo "")
if [ -n "$LOCAL_VER" ]; then
    # Check npm for latest (10s timeout)
    REMOTE_VER=$(timeout 10 npm view @anthropic-ai/claude-code version 2>/dev/null || echo "")

    if [ -n "$REMOTE_VER" ] && [ "$LOCAL_VER" != "$REMOTE_VER" ]; then
        # Update all pane @cm_info to show upgrade available
        PANES=$(tmux list-panes -t "$SESSION" -F '#{pane_id}' 2>/dev/null || echo "")
        for PANE_ID in $PANES; do
            TITLE=$(tmux show-options -p -t "$PANE_ID" -v @cm_info 2>/dev/null || echo "")
            if [ -n "$TITLE" ] && ! echo "$TITLE" | grep -q "⬆"; then
                NEW_TITLE=$(echo "$TITLE" | sed "s/claude $LOCAL_VER/claude $LOCAL_VER ⬆ $REMOTE_VER/")
                tmux set-option -p -t "$PANE_ID" @cm_info "$NEW_TITLE" 2>/dev/null || true
            fi
        done
    fi
fi

# Reschedule: sleep then run again
SELF="$(cd "$(dirname "$0")" && pwd)/check-upgrade.sh"
tmux run-shell -b "sleep $INTERVAL && bash '$SELF' '$SESSION' '$INTERVAL'" 2>/dev/null || true
""")


def tmux_session_exists(session_name: str) -> bool:
    """Check if a tmux session with the given name exists."""
    result = subprocess.run(
        ["tmux", "has-session", "-t", session_name],
        capture_output=True,
    )
    return result.returncode == 0


def run_tmux(args: list[str]) -> subprocess.CompletedProcess:
    """Run a tmux command safely via argument list."""
    return subprocess.run(
        ["tmux"] + args,
        capture_output=True,
        text=True,
    )


def create_session(
    projects: list[dict],
    layout: str,
    session_name: str,
    detach: bool,
    dep_info: dict,
    upgrade_check_interval: int,
) -> None:
    """Create the tmux session with all panes."""
    claude_version = dep_info.get("claude_version", "unknown")

    # Generate config and scripts
    generate_tmux_conf(
        TMUX_CONF_PATH, SCRIPTS_DIR, session_name, upgrade_check_interval
    )
    generate_scripts(SCRIPTS_DIR)

    # Create session with a default shell (not the wrapper directly)
    # All panes start as shells; we send-keys to each for consistency
    first = projects[0]
    subprocess.run(
        [
            "tmux", "new-session",
            "-d",
            "-s", session_name,
            "-f", str(TMUX_CONF_PATH),
            "-c", str(first["path"]),
        ],
        check=True,
    )

    # Source the tmux config explicitly (the -f flag on new-session is unreliable)
    run_tmux(["source-file", str(TMUX_CONF_PATH)])

    # Create remaining panes via layout
    layout_cmds = build_layout_commands(layout, projects, session_name)
    for cmd in layout_cmds:
        subprocess.run(cmd, check=False)

    # Launch wrapper in each pane via send-keys (consistent for all panes)
    for i, proj in enumerate(projects):
        title = f"[{proj['name']}] claude {claude_version} ● running"

        # Set pane info via per-pane user option (not pane_title, which Claude overwrites)
        run_tmux([
            "set-option", "-p", "-t", f"{session_name}:0.{i}",
            "@cm_info", title,
        ])

        # Store project color for use in pane-border-format
        run_tmux([
            "set-option", "-p", "-t", f"{session_name}:0.{i}",
            "@cm_color", proj["color"],
        ])

        # Set per-pane background color if configured
        bg = proj.get("bg", "")
        if bg:
            run_tmux([
                "select-pane", "-t", f"{session_name}:0.{i}",
                "-P", f"bg={bg}",
            ])

        # Build env vars for skill/model/effort
        env_prefix = ""
        model = proj.get("model", "")
        effort = proj.get("effort", "")
        system_prompt = proj.get("system_prompt", "")
        if model:
            env_prefix += f"CM_MODEL='{model}' "
        if effort:
            env_prefix += f"CM_EFFORT='{effort}' "
        if system_prompt:
            # Write prompt to a file (avoids shell quoting issues)
            prompt_file = SCRIPTS_DIR / f"prompt-{i}.txt"
            prompt_file.write_text(system_prompt)
            os.chmod(prompt_file, 0o600)
            env_prefix += f"CM_SYSTEM_PROMPT_FILE='{prompt_file}' "

        # Launch wrapper — clear first so the command line is not visible
        wrapper = str(SCRIPTS_DIR / "pane-wrapper.sh")
        proj_path = str(proj["path"])
        proj_name = proj["name"]
        proj_color = proj["color"]
        run_tmux([
            "send-keys", "-t", f"{session_name}:0.{i}",
            f"clear && {env_prefix}bash '{wrapper}' '{proj_path}' '{proj_name}' '{proj_color}'",
            "Enter",
        ])

    # Attach or stay detached
    if not detach:
        os.execvp("tmux", ["tmux", "attach-session", "-t", session_name])
    else:
        print(f"Session '{session_name}' created in background.")
        print(f"Attach with: tmux attach -t {session_name}")


