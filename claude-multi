def main() -> None:
    """Main entry point."""
    args = parse_args()

    if args.keys:
        print(KEYS_HELP)
        return

    if args.skills:
        print("Available skill presets:\n")
        for name, info in sorted(SKILL_PRESETS.items()):
            print(f"  {name:12s}  {info['prompt'][:80]}...")
        print(f"\nUsage in config.toml:")
        print(f'  [[projects]]')
        print(f'  path = "~/my-project"')
        print(f'  skill = "quant"')
        print(f'  model = "opus"  # optional: opus, sonnet, haiku')
        return

    config = load_config(args.config)
    dep_info = check_dependencies()

    layout = args.layout or config["layout"]

    if args.projects:
        project_paths = args.projects
    else:
        project_paths = []

    if not project_paths and not config["projects"]:
        print(
            "ERROR: No projects specified. "
            "Pass project paths as arguments or define them in config:\n"
            f"  {args.config}",
            file=sys.stderr,
        )
        sys.exit(1)

    projects = validate_projects(
        project_paths,
        palette=config["palette"],
        config_projects=config["projects"],
    )

    if not projects:
        print("ERROR: No valid project paths found.", file=sys.stderr)
        sys.exit(1)

    # Add team collaboration context for multi-pane projects
    projects = enrich_with_team_context(projects)

    # Sort by project path so same-project panes are grouped together
    # This ensures left column = project A, right column = project B in grid layout
    projects.sort(key=lambda p: str(p["path"]))

    session_name = sanitize_name(args.session)

    if tmux_session_exists(session_name):
        print(f"Session '{session_name}' already exists. Attaching...")
        if not args.detach:
            os.execvp("tmux", ["tmux", "attach-session", "-t", session_name])
        else:
            print(f"Attach with: tmux attach -t {session_name}")
        return

    create_session(
        projects, layout, session_name, args.detach, dep_info,
        config["upgrade_check_interval"],
    )


if __name__ == "__main__":
    main()
